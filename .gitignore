# macOS
.DS_Store

# Runtime / session data (changes too often, not useful to track)
agents/
canvas/
completions/
credentials/
devices/
identity/
logs/
update-check.json
cron/
delivery-queue/

# Browser/Telegram state
browser/
telegram/

# Media (generated files)
media/

# SQLite / db files
**/*.db
**/*.sqlite

# Config backups
*.bak
*.bak.*

# Sensitive (auth tokens)
agents/*/agent/auth-profiles.json
exec-approvals.json

# Workspace memory (daily logs — optional, uncomment to exclude)
# workspace/doloris/memory/
# workspace/miku/memory/

# Keep automation scripts tracked in git
!scripts/
!scripts/*.sh

# Reports and artifacts
backups/
openclaw.json.bak
openclaw.json.bak.*
reports/*.json
reports/*.md
!reports/README.md
artifacts/

# Python cache
**/__pycache__/
*.py[cod]
*.so

# Wrangler/Cloudflare
**/.wrangler/

# Backup files
*.backup
*.backup-*

# Workspace generated content (follow workspace rules in AGENTS.md)
workspace/**/.openclaw/
workspace/**/memory/heartbeat-state.json
