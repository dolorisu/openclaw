# macOS
.DS_Store

# Runtime / session data (changes too often, not useful to track)
agents/
canvas/
completions/
credentials/
devices/
identity/
logs/
update-check.json
cron/
delivery-queue/

# Workspace state
workspace/**/.openclaw/
workspace/doloris/memory/heartbeat-state.json

# Media
media/

# SQLite / db files
**/*.db
**/*.sqlite

# Config backups
*.bak
*.bak.*

# Sensitive (auth tokens)
agents/*/agent/auth-profiles.json
exec-approvals.json

# Workspace memory (daily logs — optional, uncomment to exclude)
# workspace/doloris/memory/
# workspace/miku/memory/

# Keep automation scripts tracked in git
!scripts/
!scripts/*.sh

# Config backups (but openclaw.json is tracked for private backup/sync between deployments)
backups/
openclaw.json.bak
openclaw.json.bak.*
reports/*.json
reports/*.md
!reports/README.md
artifacts/
